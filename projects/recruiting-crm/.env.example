# ─────────────────────────────────────────────────────────────────────────────
# CRI CRM — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres password used by docker-compose to build DATABASE_URL automatically.
# Generate with:  openssl rand -base64 32
DB_PASSWORD=change_me_strong_password

# Full database connection string. Required when running Node directly
# (npm run dev). docker-compose can also build this from DB_PASSWORD.
DATABASE_URL=postgresql://cri:<password>@localhost:5432/cri_crm?connection_limit=5

# NextAuth secret — used to sign JWT session tokens.
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=change_me_strong_secret

# The public URL of the CRM (no trailing slash).
# Local dev:   http://localhost:3000
# Production:  https://crm.corporaterecruitersinc.com
NEXTAUTH_URL=http://localhost:3000

# development | production
NODE_ENV=development

# ── Optional ─────────────────────────────────────────────────────────────────

# Sentry DSN for error monitoring. Free tier at sentry.io.
# SENTRY_DSN=https://xxx@ooo.ingest.sentry.io/yyy

# Uptime monitoring: point UptimeRobot or Azure Monitor at /api/health
# (returns HTTP 200 when the app is healthy).
