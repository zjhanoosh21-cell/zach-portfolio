generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  tasks     Task[]     @relation("TaskAssignee")
  prospects Prospect[] @relation("ProspectAssignee")
  notes     FeedNote[]

  @@map("users")
}

model AppSettings {
  id     String @id @default("singleton")
  apiKey String

  @@map("app_settings")
}

model Phase {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks Task[]

  @@map("phases")
}

model Task {
  id          String    @id @default(cuid())
  phaseId     String
  title       String
  description String?
  status      String    @default("pending")
  assigneeId  String?
  dueDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  phase    Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  assignee User? @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([phaseId])
  @@index([status])
  @@map("tasks")
}

model Prospect {
  id               String    @id @default(cuid())
  name             String
  businessName     String?
  industry         String?
  email            String?
  phone            String?
  website          String?
  notes            String?
  status           String    @default("scraped")
  source           String    @default("manual")
  assigneeId       String?
  followUpDate     DateTime?
  outreachSentAt   DateTime?
  outreachTemplate String?
  mockupPath       String?
  mockupUrl        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignee  User?      @relation("ProspectAssignee", fields: [assigneeId], references: [id])
  deal      Deal?
  feedNotes FeedNote[]

  @@index([status])
  @@index([source])
  @@index([followUpDate])
  @@map("prospects")
}

model Deal {
  id             String    @id @default(cuid())
  prospectId     String    @unique
  proposalAmount Int?
  retainerAmount Int?
  closeDate      DateTime?
  status         String    @default("active")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("deals")
}

model FeedNote {
  id         String   @id @default(cuid())
  content    String
  authorId   String?
  prospectId String?
  createdAt  DateTime @default(now())

  author   User?     @relation(fields: [authorId], references: [id])
  prospect Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("feed_notes")
}

model Document {
  id        String   @id @default(cuid())
  title     String
  category  String   @default("general")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("documents")
}
